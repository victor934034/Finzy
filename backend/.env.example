# =====================================================
# FinanceIA — Backend Environment Variables
# Copie este arquivo como .env e preencha os valores
# =====================================================

# ── IA (coloque ao menos 1 chave) ───────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Supabase ─────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# ── Pluggy Open Finance (opcional) ───────────────────
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ── Gmail OAuth (opcional) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/gmail/callback

# ── Servidor ─────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
