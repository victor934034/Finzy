# =====================================================
# FinanceIA — Backend + Frontend (serviço único)
# =====================================================

# ── IA (coloque ao menos 1 chave) ───────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Supabase ─────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui
# Chave pública (anon) — usada pelo frontend via /env-config.js
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── Pluggy Open Finance (opcional) ───────────────────
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ── Gmail OAuth (opcional) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://SEU_DOMINIO/api/integrations/gmail/callback

# ── Servidor ─────────────────────────────────────────
PORT=3001
NODE_ENV=production
